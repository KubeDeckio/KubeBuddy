{
  "name": "kubebuddy-headlamp-plugin",
  "version": "0.1.0",
  "description": "KubeBuddy Kubernetes checks for Headlamp",
  "author": {
    "name": "KubeDeck",
    "url": "https://kubedeck.io"
  },
  "homepage": "https://kubebuddy.kubedeck.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/KubeDeckio/KubeBuddy.git",
    "directory": "headlamp-plugin"
  },
  "scripts": {
    "validate:native-handlers": "node scripts/validate-native-handlers.mjs",
    "generate:checks": "node scripts/generate-check-catalog.mjs && npm run validate:native-handlers",
    "prestart": "npm run generate:checks",
    "start": "headlamp-plugin start",
    "prebuild": "npm run generate:checks",
    "build": "headlamp-plugin build",
    "format": "headlamp-plugin format",
    "prelint": "npm run generate:checks",
    "lint": "headlamp-plugin lint",
    "lint-fix": "headlamp-plugin lint --fix",
    "package": "headlamp-plugin package",
    "pretsc": "npm run generate:checks",
    "tsc": "headlamp-plugin tsc",
    "storybook": "headlamp-plugin storybook",
    "storybook-build": "headlamp-plugin storybook-build",
    "test": "headlamp-plugin test",
    "i18n": "headlamp-plugin i18n"
  },
  "keywords": [
    "headlamp",
    "headlamp-plugin",
    "kubebuddy",
    "kubernetes",
    "kubernetes-checks"
  ],
  "prettier": "@headlamp-k8s/eslint-config/prettier-config",
  "eslintConfig": {
    "extends": [
      "@headlamp-k8s",
      "prettier",
      "plugin:jsx-a11y/recommended"
    ]
  },
  "devDependencies": {
    "@kinvolk/headlamp-plugin": "^0.13.1",
    "yaml": "^2.8.1"
  },
  "overrides": {
    "form-data": "4.0.6",
    "undici": "7.28.0",
    "typescript": "5.6.2"
  }
}
